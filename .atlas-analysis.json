  "keyFeatures": [
    "Real-time parking spot availability with interactive map",
    "Secure user authentication and profile management",
    "Digital wallet with credit balance and payment processing",
    "QR code ticket generation and scanning",
    "Push notifications for reservation updates",
    "Vehicle management system",
    "Reservation history and tracking",
    "Community features with friends and ranking",
    "AI-powered support chat",
    "Multi-platform support (iOS, Android, Web)"
  ],
  "publicApiSurface": [
    "useReservar - Reservation creation and management hook",
    "useLogin - Authentication and session management hook",
    "useHistorial - Reservation history retrieval hook",
    "useTarjetas - Payment card management hook",
    "useSupportChat - AI support chat integration hook",
    "useAmigos - Friend management and social features hook",
    "useSeguridad - Security settings and biometric authentication hook",
    "ParkingMap - Interactive parking lot visualization component",
    "TicketModal - QR ticket display and management component",
    "ScannerModal - QR code scanning component",
    "MyQRModal - Personal QR code display component"
  ]
